# AI-KnowledgeOps backend configuration example.
# Copy this file to .env and adjust paths for your machine.

BASE_DIR=/absolute/path/to/AI-KnowledgeOps
CONTAINER_BASE_DIR=/

MINERU_CONTAINER=mineru-vllm

EMBED_MODEL=bge-m3:latest
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434

CHUNK_SIZE=8000
POST_PROCESS_MAX_SIZE=1500
POST_PROCESS_MIN_SIZE=200
OVERLAP_SIZE=200

QDRANT_COLLECTION_NAME=documents
QDRANT_URL=http://localhost:6333

QWEN_VL_MODEL=qwen2.5vl:7b
QWEN_VL_VERIFY_MODEL=qwen3-vl:8b-instruct
QWEN_VL_TIMEOUT=30
ENABLE_IMAGE_VERIFICATION=true
MAX_IMAGE_VERIFY_COUNT=5
MAX_IMAGES=5

CORS_ORIGINS=http://localhost:8902
ENABLE_IMAGE_SUMMARY=false
